# CoachOS API — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.

# ─── AI Provider ────────────────────────────────
# Options: mock | simulated-openai | deepseek
COACHOS_AI_PROVIDER=mock

# Required when COACHOS_AI_PROVIDER=deepseek
BYTEZ_API_KEY=

# ─── Storage ────────────────────────────────────
# Options: json | postgres_relational
COACHOS_STORAGE_MODE=json

# ─── Billing Provider ───────────────────────────
# Options: mock | simulated-stripe
COACHOS_BILLING_PROVIDER=mock
STRIPE_MODE=test
STRIPE_SECRET_KEY=

# ─── Proof Card ─────────────────────────────────
COACHOS_PROOF_PROVIDER=mock

# ─── Database (PostgreSQL) ───────────────────────
# Only needed when COACHOS_STORAGE_MODE=postgres_relational
DATABASE_URL=postgresql://user:password@localhost:5432/coachos

# ─── Server ─────────────────────────────────────
PORT=4000
NODE_ENV=development
