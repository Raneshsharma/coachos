{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@coachos/domain": [
        "packages/domain/src"
      ],
      "@coachos/ui": [
        "packages/ui/src"
      ]
    }
  }
}
